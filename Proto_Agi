                if interest not in self.user_interests:
                    self.user_interests.append(interest)
                    if len(self.user_interests) > 30:
                        self.user_interests = self.user_interests[-30:]

    def to_dict(self) -> dict:
        return {"user_name":self.user_name,"learned_user":self.learned_user[-200:],
                "learned_self":self.learned_self[-200:],"opinion_of_user":self.opinion_of_user,
