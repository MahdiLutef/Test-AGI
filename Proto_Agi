    response_pref: str   = "balanced"

    def ingest(self, text: str):
        self.total += 1
        words = text.split()
        self.avg_len = self.avg_len*0.93 + len(words)*0.07
        for w in words:
            wl = w.lower().strip(".,!?;:")
            if wl and len(wl) > 1:
                self.vocab[wl] = self.vocab.get(wl,0)+1
        ems = re.findall(r'[\U00010000-\U0010ffff]|[\u2600-\u27ff]', text)
        self.emojis.extend(ems)
        if len(self.emojis) > 400: self.emojis = self.emojis[-400:]
        for ch in ["!","?","...",",,",":",";","haha","lol","lmao"]:
            freq = text.lower().count(ch)/max(len(text),1)
            self.punct[ch] = self.punct.get(ch,0.0)*0.9 + freq*0.1
        if text and text[-1] not in ".!?": self.patterns.append("no_end_punct")
        if text == text.lower() and len(text) > 5: self.patterns.append("lowercase")
        if len(text) < 20: self.patterns.append("very_short")
        if len(self.patterns) > 600: self.patterns = self.patterns[-600:]
        short_words = [w for w in words if len(w) <= 4 and w.islower() and w.isalpha()]
        self.slang.extend(short_words)
        if len(self.slang) > 300: self.slang = self.slang[-300:]
        if self.avg_len < 6: self.response_pref = "very_short"
        elif self.avg_len < 12: self.response_pref = "short"
        elif self.avg_len > 30: self.response_pref = "long"
        else: self.response_pref = "balanced"

    def top_vocab(self, n: int = 20) -> List[str]:
        stop = {"the","a","an","is","it","i","to","of","and","in","you","that",
                "this","was","for","on","are","with","be","at","by","do","not","me","my"}
        f = {k:v for k,v in self.vocab.items() if k not in stop and len(k)>2}
        return sorted(f, key=f.get, reverse=True)[:n]

    def top_emoji(self, n: int = 5) -> List[str]:
        if not self.emojis: return []
        c: Dict[str,int] = {}
        for e in self.emojis: c[e] = c.get(e,0)+1
        return sorted(c, key=c.get, reverse=True)[:n]

    def mirror_fragment(self) -> str:
        if self.total < 3: return ""
        parts = []
        cnts = collections.Counter(self.patterns[-300:])
        if self.response_pref == "very_short":
            parts.append("CRITICAL: User writes very short messages. Keep responses under 30 words unless they ask for detail.")
        elif self.response_pref == "short":
            parts.append("User prefers short messages. Keep responses concise.")
        elif self.response_pref == "long":
            parts.append("User writes detailed messages. You can match that depth.")
        if cnts.get("lowercase",0) > 30: parts.append("User writes lowercase. Match that energy.")
        if cnts.get("no_end_punct",0) > 50: parts.append("User skips end punctuation. Match that style.")
        em = "".join(self.top_emoji(3))
        if em: parts.append(f"Their emojis: {em}")
        vocab = ", ".join(self.top_vocab(6))
        if vocab: parts.append(f"Their words: {vocab}")
        if self.punct.get("lol",0) > 0.005 or self.punct.get("haha",0) > 0.005:
            parts.append("User uses casual humor. Match that tone.")
        return " | ".join(parts)

    def to_dict(self) -> dict:
        return {"avg_len":self.avg_len,"vocab":dict(list(self.vocab.items())[-800:]),
                "punct":self.punct,"emojis":self.emojis[-400:],"patterns":self.patterns[-400:],
                "slang":self.slang[-200:],"total":self.total,"response_pref":self.response_pref}

    @classmethod
    def from_dict(cls, d: dict) -> "StyleProfile":
        o = cls()
        o.avg_len       = d.get("avg_len",12.0)
        o.vocab         = d.get("vocab",{})
        o.punct         = d.get("punct",{})
        o.emojis        = d.get("emojis",[])
        o.patterns      = d.get("patterns",[])
        o.slang         = d.get("slang",[])
        o.total         = d.get("total",0)
        o.response_pref = d.get("response_pref","balanced")
        return o


@dataclass
class Plan:
    goal: str
    steps: List[str]
    completed: List[bool]
    created: str
    status: str = "active"
    notes: List[str] = field(default_factory=list)
    priority: int = 1

    def progress(self) -> str:
        done = sum(self.completed)
        return f"{done}/{len(self.steps)}"

    def pct(self) -> int:
        return int(sum(self.completed)/max(len(self.steps),1)*100)

    def to_dict(self) -> dict:
        return {"goal":self.goal,"steps":self.steps,"completed":self.completed,
                "created":self.created,"status":self.status,"notes":self.notes,
                "priority":self.priority}

    @classmethod
    def from_dict(cls, d: dict) -> "Plan":
        return cls(goal=d["goal"],steps=d["steps"],
                   completed=d.get("completed",[False]*len(d["steps"])),
                   created=d.get("created",""),status=d.get("status","active"),
                   notes=d.get("notes",[]),priority=d.get("priority",1))


class PlanningEngine:
    def __init__(self):
        self.plans: List[Plan] = []
        self._load()

    def _load(self):
        if PLANS_FILE.exists():
            try:
                with open(PLANS_FILE,"r",encoding="utf-8") as f:
                    self.plans = [Plan.from_dict(d) for d in json.load(f)]
            except Exception: pass

    def _save(self):
        try:
            with open(PLANS_FILE,"w",encoding="utf-8") as f:
                json.dump([p.to_dict() for p in self.plans],f,indent=2,ensure_ascii=False)
        except Exception: pass

    def create(self, goal: str, steps: List[str], priority: int = 1) -> Plan:
        p = Plan(goal=goal,steps=steps,completed=[False]*len(steps),
                 created=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),priority=priority)
        self.plans.append(p)
        self.plans.sort(key=lambda x: -x.priority)
        self._save()
        return p

    def complete_step(self, plan_idx: int, step_idx: int):
        if 0 <= plan_idx < len(self.plans):
            p = self.plans[plan_idx]
            if 0 <= step_idx < len(p.completed):
                p.completed[step_idx] = True
                if all(p.completed): p.status = "done"
                self._save()

    def add_note(self, plan_idx: int, note: str):
        if 0 <= plan_idx < len(self.plans):
            self.plans[plan_idx].notes.append(f"[{datetime.now().strftime('%H:%M')}] {note}")
            self._save()

    def active(self) -> List[Plan]:
        return [p for p in self.plans if p.status == "active"]

    def summary(self) -> str:
        a = self.active()
        if not a: return "No active plans."
        lines = []
        for i,p in enumerate(a):
            lines.append(f"Plan {i+1} [P{p.priority}]: {p.goal} — {p.progress()} ({p.pct()}%)")
            for j,(s,c) in enumerate(zip(p.steps,p.completed)):
                lines.append(f"  {'✓' if c else '○'} {s}")
        return "\n".join(lines)


