def _describe_image_local(image_path: str) -> str:
    if not PIL_AVAILABLE or Image is None:
        return "Image loaded. PIL not available for analysis."
    try:
        img = Image.open(image_path)
        w, h = img.size
        mode  = img.mode
        fmt   = img.format or Path(image_path).suffix.upper()
        desc  = f"Image: {w}x{h} pixels, {mode} mode, {fmt} format."
        if NUMPY_AVAILABLE and np is not None:
            arr = np.array(img.convert("RGB"))
            mean_rgb = arr.mean(axis=(0,1))
            brightness = mean_rgb.mean() / 255.0
            desc += f" Average color: RGB({int(mean_rgb[0])},{int(mean_rgb[1])},{int(mean_rgb[2])}). Brightness: {brightness:.0%}."
            if brightness > 0.7: desc += " The image appears bright/light."
            elif brightness < 0.3: desc += " The image appears dark."
            edges_rough = abs(arr[1:,:,:].astype(int) - arr[:-1,:,:].astype(int)).mean()
            if edges_rough > 30: desc += " The image has significant detail or contrast."
            else: desc += " The image appears relatively smooth or uniform."
        return desc
    except Exception as e:
        return f"Could not analyze image: {e}"


class SafeEval:
    OPS = {ast.Add:operator.add, ast.Sub:operator.sub, ast.Mult:operator.mul,
           ast.Div:operator.truediv, ast.FloorDiv:operator.floordiv,
           ast.Mod:operator.mod, ast.Pow:operator.pow,
           ast.USub:operator.neg, ast.UAdd:operator.pos}
    FNS = {"abs":abs,"round":round,"min":min,"max":max,"sum":sum,"len":len,"pow":pow,
           "int":int,"float":float,"str":str}

    @classmethod
    def eval(cls, expr: str) -> Any:
        return cls._n(ast.parse(expr, mode="eval").body)

    @classmethod
    def _n(cls, n):
        if isinstance(n, ast.Constant): return n.value
        if isinstance(n, ast.BinOp):
            op = cls.OPS.get(type(n.op))
            if not op: raise ValueError("Operator not allowed")
            return op(cls._n(n.left), cls._n(n.right))
        if isinstance(n, ast.UnaryOp):
            op = cls.OPS.get(type(n.op))
            if not op: raise ValueError("Unary not allowed")
            return op(cls._n(n.operand))
        if isinstance(n, ast.Call):
            if isinstance(n.func, ast.Name) and n.func.id in cls.FNS:
                return cls.FNS[n.func.id](*[cls._n(a) for a in n.args])
            raise ValueError("Call not allowed")
        if isinstance(n, (ast.List, ast.Tuple)):
            return [cls._n(e) for e in n.elts]
        if isinstance(n, ast.Name) and n.id in cls.FNS:
            return cls.FNS[n.id]
        raise ValueError(f"Not allowed: {type(n).__name__}")

    @classmethod
    def safe(cls, e: str) -> bool:
        return not any(b in e.lower() for b in
                       ["import","exec","eval","__","open","os.","sys.",
                        "subprocess","compile","globals","locals"])


