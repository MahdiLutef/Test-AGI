            "vector_db":       "ChromaDB" if self.collection else "File-based",
            "tools":           len(self.tools),
            "web_search":      WEB_SEARCH_AVAILABLE,
            "model_loaded":    self.llama is not None or self.hf_model is not None,
            "gpu":             gpu,
