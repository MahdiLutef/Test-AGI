def detect_n_ctx() -> int:
    if not (TORCH_AVAILABLE and torch is not None):
        return 4096
    try:
        if not torch.cuda.is_available():
            return 4096
        free = torch.cuda.mem_get_info()[0] / (1024**3)
        if free >= 3.5: return 8192
        if free >= 2.5: return 4096
        if free >= 1.5: return 2048
        return 1024
    except Exception:
        return 4096


def google_translate_free(text: str, target: str = "ar") -> Optional[str]:
    if DEEP_TRANSLATOR_AVAILABLE and GoogleTranslator is not None:
        try:
            return GoogleTranslator(source="auto", target=target).translate(text)
        except Exception:
            pass
    try:
        params = urllib.parse.urlencode({
            "client":"gtx","sl":"auto","tl":target,"dt":"t","q":text[:4500]})
        req = urllib.request.Request(
            f"https://translate.googleapis.com/translate_a/single?{params}",
            headers={"User-Agent":"Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=9) as r:
            data = json.loads(r.read().decode())
        return "".join(b[0] for b in data[0] if b[0]).strip() or None
    except Exception:
        return None


def speak_arabic(text: str):
    if not text: return
    if GTTS_AVAILABLE and gTTS is not None:
        def _run():
            try:
                tts = gTTS(text=text[:500], lang="ar", slow=False)
                tmp = tempfile.NamedTemporaryFile(suffix=".mp3", delete=False)
                tmp.close()
                tts.save(tmp.name)
                if sys.platform == "win32":
                    try:
                        import winsound
                        winsound.PlaySound(tmp.name, winsound.SND_FILENAME)
                    except Exception:
                        try: os.startfile(tmp.name); time.sleep(4)
                        except Exception: pass
                elif sys.platform == "darwin":
                    subprocess.run(["afplay", tmp.name])
                else:
                    for p in [["mpg123"],["mpg321"],["ffplay","-nodisp","-autoexit"]]:
                        try: subprocess.run(p+[tmp.name], timeout=10); break
                        except Exception: pass
                try: os.unlink(tmp.name)
                except Exception: pass
            except Exception as e:
                logger.warning(f"gTTS: {e}")
                _ps_arabic(text)
        threading.Thread(target=_run, daemon=True).start()
        return
    threading.Thread(target=lambda: _ps_arabic(text), daemon=True).start()


def _ps_arabic(text: str):
    if sys.platform != "win32": return
    try:
        safe = re.sub(r"['\"\\\n\r]", " ", text[:400])
        script = (
            "Add-Type -AssemblyName System.Speech; "
            "$s = New-Object System.Speech.Synthesis.SpeechSynthesizer; "
            "foreach ($v in $s.GetInstalledVoices()) { "
            "  if ($v.VoiceInfo.Culture.Name -like 'ar*') { "
            "    $s.SelectVoice($v.VoiceInfo.Name); break } }; "
            f"$s.Speak('{safe}')"
        )
        subprocess.run(["powershell","-WindowStyle","Hidden","-NonInteractive","-Command",script],
                       capture_output=True, timeout=30)
    except Exception as e:
        logger.warning(f"PS Arabic: {e}")


