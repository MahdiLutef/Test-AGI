    def _process_q():
        try:
            while not q.empty():
                kind,payload = q.get_nowait()
                if kind == "answer":
                    if payload.startswith("IMAGE:"):
                        img_path = payload[6:]
                        _append(chat,f"\n  Proto\n","bot_lbl")
                        _append(chat,f"  [Generated image: {Path(img_path).name}]\n","img_txt")
                        _append(chat,"  ──────────────────────────────────────────────────────\n","div")
                        if tab_var.get() == "image": _display_image_in_canvas(img_path)
                    else:
                        tag = "anger_txt" if proto.emotion.mood in ("angry","frustrated") else "bot_txt"
                        _append(chat,f"\n  Proto\n","bot_lbl")
                        _append(chat,f"  {payload}\n",tag)
                        _append(chat,"  ──────────────────────────────────────────────────────\n","div")
                elif kind == "mono":
                    if payload:
                        _set_mono(payload)
                        _append(chat,f"  ┄ {payload[:100]}{'…' if len(payload)>100 else ''}\n","mono_txt")
                elif kind == "call_in":
                    _append(chat,f"\n  You (voice)\n","user_lbl")
                    _append(chat,f"  {payload}\n","user_txt")
                    _append(chat,"  ──────────────────────────────────────────────────────\n","div")
                elif kind == "thought":
                    _append_thought(payload)
                elif kind == "th_full":
                    if payload and show_th_var.get():
                        thought_box.configure(state=NORMAL)
                        thought_box.insert(END,f"\n{payload}\n")
                        thought_box.see(END)
                        thought_box.configure(state=DISABLED)
                elif kind == "debate":
                    _append(chat,f"\n  Proto [Internal Debate]\n","bot_lbl")
                    _append(chat,f"  {payload}\n","debate_txt")
                    _append(chat,"  ──────────────────────────────────────────────────────\n","div")
                elif kind == "err":
                    _append(chat,f"\n  ⚠ ERROR: {payload}\n","sys_txt")
                elif kind == "sys":
                    _append(chat,f"  {payload}\n","sys_txt" if not "ERROR" in str(payload).upper() else "anger_txt")
                elif kind == "status":
                    status_var.set(payload)
                elif kind == "done":
                    thinking[0] = False
                    if anim_id[0]: root.after_cancel(anim_id[0]); anim_id[0] = None
                    status_var.set("ONLINE")
                    send_btn.configure(state=NORMAL)
                    entry.configure(state=NORMAL)
                    entry.focus_set()
                elif kind == "updates":
                    _update_mem(); _update_mood()
                elif kind == "arabic":
                    arabic_cache[0] = payload
                    ar_box.configure(state=NORMAL)
                    ar_box.delete(1.0,END)
                    ar_box.insert(1.0,payload,"rtl")
                    ar_box.configure(state=DISABLED)
                elif kind == "name_learned":
                    _append(chat,f"  ✓ NAME REGISTERED: {payload}\n","name_txt")
                elif kind == "milestone":
                    _append(chat,f"  ✦ MILESTONE: {payload}\n","ms_txt")
                elif kind == "new_image":
                    _append(chat,f"\n  Proto\n","bot_lbl")
                    _append(chat,f"  [Image generated: {Path(payload).name}]\n","img_txt")
                    _append(chat,"  ──────────────────────────────────────────────────────\n","div")
                    if tab_var.get() == "image": _display_image_in_canvas(payload)
                    else: tab_var.set("image"); _refresh_tabs(); _display_image_in_canvas(payload)
                elif kind == "scan":
                    scan_var.set(f"SCAN: {payload}")
        except Exception: pass
        finally:
            root.after(70,_process_q)

