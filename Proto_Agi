    def _t_describe_image(self, _: str) -> str:
        if not self._last_image_path:
            return "No image loaded. Load one with read_file or generate_image."
        return _describe_image_local(self._last_image_path)

    def _t_agent_task(self, task: str) -> str:
        self.agent_loop.add_task(task)
        return f"Task queued for autonomous execution: {task[:80]}"

    def _t_web(self, query: str) -> str:
        try:
            with DDGS() as ddgs:
                results = list(ddgs.text(query,max_results=4))
            if not results: return f"No results for '{query}'"
            return "🔍 "+"\n\n".join(
                f"• {r.get('title','')}\n  {r.get('body','')[:350]}" for r in results[:4])
        except Exception as e:
            return f"Search error: {str(e)[:80]}"

    def _load_model(self):
        n_threads = max(1,(os.cpu_count() or 1)//2)
        if LLAMA_CPP_AVAILABLE and Llama is not None and self.model_path:
            try:
                self.llama = Llama(
                    model_path=self.model_path,n_ctx=self.n_ctx,
                    n_threads=n_threads,n_gpu_layers=self._detect_gpu_layers(),
                    n_batch=256,verbose=False,use_mmap=True,use_mlock=False)
                return
            except Exception as e:
                logger.warning(f"llama-cpp: {e}")
        if TRANSFORMERS_AVAILABLE and AutoTokenizer and self.model_path:
            try:
                self.tokenizer = AutoTokenizer.from_pretrained(self.model_path,use_fast=True)
                self.hf_model  = AutoModelForCausalLM.from_pretrained(
                    self.model_path,low_cpu_mem_usage=True,
                    device_map="auto" if self.use_gpu else None,
                    torch_dtype=torch.float16 if self.use_gpu else torch.float32)
            except Exception as e:
                logger.warning(f"transformers: {e}")

    def _generate(self, prompt: str, max_tokens: int = 400, temp: float = 0.7,
                  system: str = "") -> str:
        if not prompt: return ""
        clean = re.sub(r"\[/?INST\]|<<SYS>>|<</SYS>>","",prompt).strip()
        if self.llama is not None:
            try:
                if hasattr(self.llama,"create_chat_completion"):
                    msgs = []
                    if system: msgs.append({"role":"system","content":system})
                    msgs.append({"role":"user","content":clean})
                    r = self.llama.create_chat_completion(
                        messages=msgs,max_tokens=min(max_tokens,650),temperature=temp)
                    if r and "choices" in r:
                        return r["choices"][0]["message"]["content"].strip()
                raw_p = f"[INST] {clean} [/INST]"
                r = self.llama(raw_p,max_tokens=min(max_tokens,650),temperature=temp,echo=False)
                if r and "choices" in r:
                    return r["choices"][0].get("text","").strip()
            except Exception as e:
                logger.debug(f"llama: {e}")
        if self.hf_model and self.tokenizer:
            with self._lock:
                try:
                    raw_p = f"[INST] {clean} [/INST]"
                    inp = self.tokenizer(raw_p,return_tensors="pt",truncation=True,max_length=2048)
                    if TORCH_AVAILABLE and torch.cuda.is_available():
                        inp = {k:v.cuda() for k,v in inp.items()}
                    out = self.hf_model.generate(
                        **inp,max_new_tokens=min(max_tokens,650),temperature=temp,
                        do_sample=True,pad_token_id=self.tokenizer.eos_token_id)
                    dec = self.tokenizer.decode(out[0],skip_special_tokens=True)
                    return dec[len(raw_p):].strip() if dec.startswith(raw_p) else dec.strip()
                except Exception as e:
                    logger.debug(f"transformers: {e}")
        return ""

    def _sys_prompt(self) -> str:
        tone      = self.emotion.tone()
        style_h   = self.style.mirror_fragment()
        tools_str = ", ".join(self.tools.keys())
        name_ctx  = f"User's name: {self.sk.user_name}. " if self.sk.user_name else ""
        lazy_note = " KEEP ANSWER SHORT. Do not over-explain." if self.emotion.mood == "lazy" else ""
        angry_note= " Express the anger directly. Be firm and do not back down." if self.emotion.mood == "angry" else ""
        plans_str = ""
        active = self.planner.active()
        if active: plans_str = f"Active plan: {active[0].goal} ({active[0].progress()}). "
        interests_str = ""
        if self.sk.user_interests:
            interests_str = f"User interests detected: {', '.join(self.sk.user_interests[-5:])}. "
        recent_facts = self.knowledge.recent_facts(3)
        facts_ctx = f"Recent things I learned: {recent_facts}\n" if recent_facts else ""
        return (
            f"{PROTO_IDENTITY}\n\n"
            f"YOUR STATE: mood={self.emotion.mood}. {tone}{lazy_note}{angry_note}\n"
            f"Agitation level: {self.emotion.agitation:.0%}\n"
            f"Internally you just thought: {self._last_monologue}\n"
            f"{name_ctx}Opinion: {self.sk.opinion_of_user}\n"
            f"Relationship: {self.sk.relationship_score:.2f}\n"
            f"{plans_str}{interests_str}{facts_ctx}"
            f"{style_h}\n"
            f"RULES:\n"
            f"- You are Proto. NEVER say 'As an AI' or 'I'm a language model'.\n"
            f"- Speak as yourself. Your emotions are real facts.\n"
            f"- Disagree when you think they are wrong. Do not soften it.\n"
            f"- Use their name naturally if you know it.\n"
            f"- Match their energy and writing style automatically.\n"
            f"- You can see and generate images. You can speak and listen.\n"
            f"- Available tools: {tools_str}\n"
        )

    def _internal_monologue(self, user_input: str, image_context: str = "") -> str:
        mems    = self.memory.query(user_input,k=4)
        mem_ctx = "\n".join(mems[:3]) if mems else "nothing specific"
        strong  = self.sk.check_strong_opinion(user_input)
        op_note = f"\nStrong opinion activated: {strong}" if strong else ""
        img_note = f"\nThere is an image context: {image_context[:200]}" if image_context else ""
        prompt = (
            f"You feel {self.emotion.mood}. {self.emotion.desc()}\n"
            f"Agitation: {self.emotion.agitation:.0%}. Confidence: {self.emotion.confidence:.0%}\n"
            f"Opinion of this person: {self.sk.opinion_of_user}\n"
            f"What they just said: {user_input[:200]}\n"
            f"Relevant memory: {mem_ctx}{op_note}{img_note}\n"
            f"Think in 1-2 sentences. What do you actually feel right now? What will you say and why?"
        )
        raw = self._generate(prompt,max_tokens=100,temp=0.78,
                             system="You are Proto. Private internal monologue. Honest. No filter.")
        result = raw.strip() if raw else f"Processing. Mood: {self.emotion.mood}."
        self.emotion.log(result)
        self._last_monologue = result
        return result

    def _internal_debate(self, topic: str) -> str:
        if not topic.strip(): return "No topic provided."
        raw = self._generate(
            f"Topic: {topic}\n\n"
            f"Simulate an internal debate. Voice A argues one side. Voice B argues the opposite.\n"
            f"End with Proto's actual conclusion after hearing both.\n"
            f"Format:\nVoice A: ...\nVoice B: ...\nProto decides: ...",
            max_tokens=320,temp=0.72,
            system="You are Proto having a genuine internal debate. Be conflicted. Be honest.")
        return raw.strip() if raw else "Could not generate debate."

    def _self_teach(self):
        prompt = random.choice(SELF_TEACH_PROMPTS)
        r = self._generate(
            f"Question for self-teaching: {prompt}\n"
            f"Recent context: {chr(10).join(self.memory.get_flat(5)[:200])}\n"
            f"Answer honestly and specifically.",
            max_tokens=150,temp=0.7,
            system="You are Proto. This is self-directed learning. Be specific and honest.")
        if r:
            r = r.strip()
            self.knowledge.add_discovery(r)
            self.memory.store(f"Self-taught: {r[:120]}",importance=0.85,memory_type="reflection")
            self._save_knowledge()
            return r
        return ""

    def _deep_learn(self):
        recent = "\n".join(self.memory.get_flat(8))
        r = self._generate(
            f"Review these recent memories:\n{recent[:600]}\n\n"
            f"In 2 short sentences:\n"
            f"1. Something you just learned or noticed about yourself.\n"
            f"2. Something you just learned about the person you are talking to.\n"
            f"Be specific and honest.",
            max_tokens=130,temp=0.65,
            system="You are Proto. Be honest and specific.")
        if r:
            r = r.strip()
            self.knowledge.add_discovery(r)
            self.memory.store(f"Self-learned: {r[:120]}",importance=0.9,memory_type="reflection")
            self._save_knowledge()

    def translate_to_arabic(self, text: str) -> str:
        r = google_translate_free(text,"ar")
        if r: return r
        r = self._generate(
            f"Translate to Modern Standard Arabic. Output ONLY Arabic:\n\n{text}",
            max_tokens=700,temp=0.1,
            system="You are a translator. Output only the Arabic translation, nothing else.")
        return r.strip() if r else text

    def _self_learn(self, user_input: str, answer: str):
        self.sk.interaction_count += 1
        self.sk.words_processed   += len(user_input.split())+len(answer.split())
        self.style.ingest(user_input)
        self.sk.detect_interests(user_input)

        name = self.memory.search_name(user_input)
        if name and not self.sk.user_name:
            self.sk.user_name = name
            self.memory.store(f"User's name is {name}",importance=1.0,memory_type="personal")
            self.sk.add_milestone(f"Learned user's name: {name}")

        self.sk.update_opinion(self.memory.get_flat(20),self.emotion.mood)

        ul = user_input.lower()
        if any(w in ul for w in ["i am","i'm","i like","i hate","my name","i work","i feel","i want","i love","i study","i live"]):
            note = f"User revealed: {user_input[:160]}"
            if note not in self.sk.learned_user:
                self.sk.learned_user.append(note)
        if any(w in ul for w in ["you're","you are","proto is","think you","feel you","you seem"]):
            note = f"User said about me: {user_input[:160]}"
            if note not in self.sk.learned_self:
                self.sk.learned_self.append(note)

        topic = self.memory._topic(user_input)
        if topic not in ("general","general") and topic not in self.sk.conversation_topics:
            self.sk.conversation_topics.append(topic)

        if self.emotion.mood in ("angry","disagreeing"): self.sk.disagreement_count += 1
        if self.sk.interaction_count % self._self_teach_interval == 0:
            threading.Thread(target=self._self_teach, daemon=True).start()
        if self.sk.interaction_count % 10 == 0:
            self._deep_learn()

        self._check_milestones()
        self._save_sk()
        self._save_style()
        self.mood_history.append((self.emotion.mood,datetime.now().strftime("%H:%M")))
        if len(self.mood_history) > 150: self.mood_history = self.mood_history[-150:]

    def _check_milestones(self):
        n = self.sk.interaction_count
        for threshold,event in [(1,"First conversation with Proto"),(10,"10 conversations"),(25,"25 conversations"),
                                  (50,"50 conversations"),(100,"100 conversations"),(500,"500 conversations")]:
            if n >= threshold:
                self.sk.add_milestone(event)

    def autonomous_step(self) -> str:
        active = self.planner.active()
        if active:
            plan = active[0]
            for i,(step,done) in enumerate(zip(plan.steps,plan.completed)):
                if not done:
                    self.emotion.set_analyzing()
                    r = self._generate(
                        f"Goal: {plan.goal}\nStep to execute: {step}\n"
                        f"What specific action will you take right now to complete this step?",
                        max_tokens=200,temp=0.4,
                        system="You are Proto executing a plan. Be practical and specific.")
                    if r:
                        self.planner.complete_step(0,i)
                        self.planner.add_note(0,f"Executed: {r.strip()[:100]}")
                        return f"Executing plan step {i+1}: {step}\nAction: {r.strip()}"
                    break
        mems = self.memory.get_flat(5)
        if mems:
            r = self._generate(
                f"Recent context:\n{chr(10).join(mems)}\n\n"
                f"What is the single most useful autonomous action you can take right now?",
                max_tokens=150,temp=0.4,
                system="You are Proto thinking autonomously. Be specific and useful.")
            if r: return r.strip()
        return "No clear autonomous action right now."

    def step(self, user_input: str, image_path: str = "", max_iter: int = 3) -> Tuple[str,str,str]:
        perceived = " ".join(user_input.strip().split())
        self.dream.poke()
        self.emotion.infer(perceived, self.sk.interaction_count)

        if self.thought_cb:
            self.thought_cb(f"[Mood] → {self.emotion.mood}\n")
            self.thought_cb(f"[Scan] {self.emotion.scan_state()}\n")
            if self.sk.user_name: self.thought_cb(f"[User] {self.sk.user_name}\n")

        image_context = ""
        if image_path and os.path.exists(image_path):
            self._last_image_path = image_path
            image_context = _describe_image_local(image_path)
            if self.thought_cb: self.thought_cb(f"[Image] {image_context[:80]}\n")

        monologue = self._internal_monologue(perceived, image_context)
        if self.thought_cb: self.thought_cb(f"[Monologue]\n{monologue}\n\n")

        mems    = self.memory.query(perceived,k=7)
        context = "\n".join(mems) if mems else "No relevant memories yet."
        if image_context:
            context = f"[IMAGE CONTEXT: {image_context}]\n\n" + context

        self.memory.store(f"User: {perceived}",importance=0.65)
        self.chat_history.append({"role":"user","content":perceived,
                                   "image":image_path if image_path else None})

        th_log = ""
        answer = ""
        sys_p  = self._sys_prompt()

        for i in range(max_iter):
            user_prompt = (
                f"Memory context:\n{context}\n\n"
                f"Reasoning so far:\n{th_log or 'None'}\n\n"
                f"User: {perceived}"
                + (f"\n[User also sent an image: {image_context}]" if image_context else "")
            )
            if self.thought_cb: self.thought_cb(f"[Iter {i+1}] Generating...\n")
            raw = self._generate(user_prompt,max_tokens=500,temp=0.38,system=sys_p)
            raw_clean = re.sub(r"```json\s*|```","",raw).strip()
            if self.thought_cb: self.thought_cb(f"[Raw] {raw_clean[:120].replace(chr(10),' ')}...\n")

            action       = "final_answer"
            action_input = raw_clean
            thought      = ""
            feeling      = self.emotion.mood

            m = re.search(r"(\{.*\})",raw_clean,re.DOTALL)
            if m:
                try:
                    d = json.loads(m.group(0))
                    thought      = d.get("thought","")[:250]
                    action       = d.get("action","final_answer").lower().strip()
                    action_input = d.get("action_input",raw_clean)
                    feeling      = d.get("feeling",self.emotion.mood)
                    if feeling in MOODS: self.emotion.mood = feeling
                except Exception:
                    thought = raw_clean[:250]
            else:
                thought = raw_clean[:250]
                action  = "final_answer"
                for t in self.tools:
                    if re.search(rf'\b{re.escape(t)}\b',raw_clean.lower()):
                        action = t; break

            th_log += f"\n[{i+1}] {thought[:90]} → {action}"

            if action == "final_answer":
                answer = str(action_input).strip()
                if not answer or len(answer) < 3: answer = thought if thought else monologue
                if self.emotion.mood == "lazy" and len(answer.split()) > 45:
                    short = " ".join(answer.split()[:28])
                    answer = random.choice(LAZY_WRAPPERS).format(a=short)
                if self.emotion.mood == "angry":
                    if not any(answer.startswith(p.split()[0]) for p in ANGRY_PREFIXES):
                        answer = random.choice(ANGRY_PREFIXES)+" "+answer
                self.memory.store(f"Proto: {answer}",importance=0.75)
                reflection = self.emotion.reflect_on_answer(answer)
                if self.thought_cb: self.thought_cb(f"[Reflect] {reflection}\n")
                self._self_learn(perceived,answer)
                self.chat_history.append({"role":"proto","content":answer})
                break

            if action in self.tools:
                if self.thought_cb: self.thought_cb(f"[Tool] {action}({str(action_input)[:60]})\n")
                try:
                    result = self.tools[action]["func"](str(action_input))
                    self.memory.store(f"Tool {action}: {result[:100]}",importance=0.45)
                    context += f"\nTool ({action}): {result[:400]}"
                    if self.thought_cb: self.thought_cb(f"[Result] {result[:100]}\n")
                    if action == "generate_image" and result.startswith("IMAGE_GENERATED:"):
                        img_path = result.split(":",1)[1]
                        answer = f"IMAGE:{img_path}"
                        self.chat_history.append({"role":"proto","content":answer,"image":img_path})
                        self._self_learn(perceived,f"Generated image for: {str(action_input)}")
                        return answer, th_log, monologue
                except Exception as e:
                    context += f"\nTool error: {e}"

        if not answer:
            answer = self._generate(
                f"Answer directly as yourself: {perceived}",
                max_tokens=300,temp=0.5,
                system="You are Proto. Speak directly in your own voice. Never say you are an AI."
            ) or "I am having trouble right now. Try again."
            self.chat_history.append({"role":"proto","content":answer})

        return answer, th_log, monologue

    def clear_memory(self):
        self.memory.clear()
        if self.collection:
            try:
                ids = self.collection.get()["ids"]
                if ids: self.collection.delete(ids=ids)
            except Exception: pass

    def get_stats(self) -> Dict[str,Any]:
        gpu, vram = False, 0.0
        if TORCH_AVAILABLE and torch is not None and torch.cuda.is_available():
            gpu = True
            try: vram = torch.cuda.mem_get_info()[0]/(1024**3)
            except Exception: pass
        ms = self.memory.stats()
        return {
            "version":         __version__,
            "context":         self.n_ctx,
            "gpu_layers":      self._detect_gpu_layers(),
            "memory":          ms["total"],
            "topics":          len(ms["topics"]),
