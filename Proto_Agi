def export_pdf(proto: Proto, output_path: str) -> bool:
    if not REPORTLAB_AVAILABLE: return False
    try:
        doc  = SimpleDocTemplate(output_path,pagesize=A4,
                                  leftMargin=2*cm,rightMargin=2*cm,
                                  topMargin=2*cm,bottomMargin=2*cm)
        ss   = getSampleStyleSheet()
        sk   = proto.sk
        ts   = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        PRP  = rl_colors.HexColor("#7c3aed")
        LPRP = rl_colors.HexColor("#a78bfa")
        DG   = rl_colors.HexColor("#334155")
        LG   = rl_colors.HexColor("#94a3b8")
        WH   = rl_colors.HexColor("#e2e8f0")
        def ps(n,**kw): return ParagraphStyle(n,parent=ss["Normal"],**kw)
        title  = ps("T",fontSize=22,textColor=PRP,fontName="Helvetica-Bold",spaceAfter=4)
        h2     = ps("H2",fontSize=14,textColor=LPRP,fontName="Helvetica-Bold",spaceBefore=18,spaceAfter=6)
        h3     = ps("H3",fontSize=10,textColor=DG,fontName="Helvetica-Bold",spaceBefore=8,spaceAfter=4)
        body   = ps("BD",fontSize=11,textColor=WH,fontName="Helvetica",spaceAfter=4,leading=16)
        user_s = ps("US",fontSize=11,textColor=LPRP,fontName="Helvetica",spaceAfter=3,leftIndent=20)
        proto_s= ps("PS",fontSize=11,textColor=WH,fontName="Helvetica",spaceAfter=3,leftIndent=20)
        small  = ps("SM",fontSize=9,textColor=DG,fontName="Helvetica",spaceAfter=2)
        italic = ps("IT",fontSize=11,textColor=rl_colors.HexColor("#c4b5fd"),fontName="Helvetica-Oblique",spaceAfter=4,leftIndent=20)
        op_s   = ps("OP",fontSize=12,textColor=rl_colors.HexColor("#c4b5fd"),fontName="Helvetica-Oblique",spaceBefore=8,spaceAfter=8)
        hr     = lambda: HRFlowable(width="100%",thickness=1,color=rl_colors.HexColor("#161628"),spaceBefore=8,spaceAfter=8)
        story  = []
        story.append(Paragraph("⬡  Proto",title))
        nm = f"  ·  {sk.user_name}" if sk.user_name else ""
        story.append(Paragraph(f"Exported {ts}  ·  v{__version__}  ·  {sk.interaction_count} interactions  ·  mood: {proto.emotion.mood}  ·  scan: {proto.emotion.scan_state()}{nm}",small))
        story.append(hr())
        story.append(Paragraph("Conversation",h2))
        for msg in proto.chat_history:
            role    = msg.get("role","user")
            content = msg.get("content","")
            if content.startswith("IMAGE:"): content = f"[Generated image: {content[6:]}]"
            content = content.replace("&","&amp;").replace("<","&lt;").replace(">","&gt;")
            if role == "user": story.append(Paragraph(f"<b>You:</b>  {content}",user_s))
            elif role == "proto": story.append(Paragraph(f"<b>Proto:</b>  {content}",proto_s))
            story.append(Spacer(1,4))
        story.append(hr())
        story.append(Paragraph("Self-Knowledge",h2))
        story.append(Paragraph(f'<i>"{sk.opinion_of_user}"</i>  ·  Relationship: {sk.relationship_score:.2f}',op_s))
        if sk.user_interests:
            story.append(Paragraph("Interests Detected",h3))
            story.append(Paragraph(", ".join(sk.user_interests),body))
        if sk.learned_user:
            story.append(Paragraph("Learned About You",h3))
            for s in sk.learned_user[-10:]: story.append(Paragraph(f"• {s}",body))
        if sk.learned_self:
            story.append(Paragraph("Learned About Himself",h3))
            for s in sk.learned_self[-10:]: story.append(Paragraph(f"• {s}",body))
        if proto.knowledge.facts:
            story.append(Paragraph("Facts Learned",h3))
            for f in proto.knowledge.facts[-8:]:
                story.append(Paragraph(f"• {f.get('fact','')}",body))
        if proto.planner.plans:
            story.append(hr()); story.append(Paragraph("Plans",h2))
            for p in proto.planner.plans[-8:]:
                story.append(Paragraph(f"<b>{p.goal}</b> — {p.progress()} ({p.pct()}%)",body))
                for s,c in zip(p.steps,p.completed):
                    story.append(Paragraph(f"  {'✓' if c else '○'}  {s}",small))
        if sk.milestones:
            story.append(hr()); story.append(Paragraph("Milestones",h2))
            mh_data = [["Time","Event","#"]]
            for m in sk.milestones[-25:]: mh_data.append([m.get("ts",""),m.get("event",""),f"#{m.get('interaction','')}"])
            mt = Table(mh_data,colWidths=[4*cm,10*cm,2*cm])
            mt.setStyle(TableStyle([
                ("BACKGROUND",(0,0),(-1,0),rl_colors.HexColor("#2d1b69")),
                ("TEXTCOLOR",(0,0),(-1,0),LPRP),("FONTNAME",(0,0),(-1,0),"Helvetica-Bold"),
                ("FONTSIZE",(0,0),(-1,-1),10),("TEXTCOLOR",(0,1),(-1,-1),LG),
                ("ROWBACKGROUNDS",(0,1),(-1,-1),[rl_colors.HexColor("#0c0c18"),rl_colors.HexColor("#09090f")]),
                ("GRID",(0,0),(-1,-1),0.3,rl_colors.HexColor("#161628")),
                ("TOPPADDING",(0,0),(-1,-1),4),("BOTTOMPADDING",(0,0),(-1,-1),4),
            ]))
            story.append(mt)
        if proto.mood_history:
            story.append(hr()); story.append(Paragraph("Mood History",h2))
            mh_data2 = [["Time","Mood","Scan State"]]
            for m,t in proto.mood_history[-30:]:
                mh_data2.append([t,m,MOODS.get(m,MOODS["neutral"])["scan"]])
            mt2 = Table(mh_data2,colWidths=[3*cm,5*cm,8*cm])
            mt2.setStyle(TableStyle([
                ("BACKGROUND",(0,0),(-1,0),rl_colors.HexColor("#2d1b69")),
                ("TEXTCOLOR",(0,0),(-1,0),LPRP),("FONTNAME",(0,0),(-1,0),"Helvetica-Bold"),
                ("FONTSIZE",(0,0),(-1,-1),9),("TEXTCOLOR",(0,1),(-1,-1),LG),
                ("ROWBACKGROUNDS",(0,1),(-1,-1),[rl_colors.HexColor("#0c0c18"),rl_colors.HexColor("#09090f")]),
                ("GRID",(0,0),(-1,-1),0.3,rl_colors.HexColor("#161628")),
                ("TOPPADDING",(0,0),(-1,-1),3),("BOTTOMPADDING",(0,0),(-1,-1),3),
            ]))
            story.append(mt2)
        if proto.dream.dream_log:
            story.append(hr()); story.append(Paragraph("Dreams",h2))
            for d in proto.dream.recent(12):
                story.append(Paragraph(f"<i>{d.get('ts','')} — {d.get('mood','')}</i>",small))
                story.append(Paragraph(f'<i>"{d.get("text","")}"</i>',italic))
                story.append(Spacer(1,6))
        story.append(Spacer(1,20))
        story.append(Paragraph(f"Generated by Proto v{__version__}  ·  {ts}",small))
        doc.build(story)
        return True
    except Exception as e:
        logger.warning(f"PDF export: {e}")
        return False


