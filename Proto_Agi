class SelfKnowledge:
    user_name: str             = ""
    learned_user: List[str]    = field(default_factory=list)
    learned_self: List[str]    = field(default_factory=list)
    opinion_of_user: str       = "I do not know you well yet. But I am paying attention."
    interaction_count: int     = 0
    words_processed: int       = 0
    fired_opinions: List[str]  = field(default_factory=list)
    disagreement_count: int    = 0
    relationship_score: float  = 0.5
    milestones: List[Dict]     = field(default_factory=list)
    conversation_topics: List[str] = field(default_factory=list)
    user_interests: List[str]  = field(default_factory=list)
    last_seen: str             = ""

    def update_opinion(self, recent: List[str], mood: str):
        pos = sum(1 for m in recent if any(w in m.lower() for w in
              ["thanks","good","great","love","appreciate","dear","<3","amazing","proto","nice"]))
        neg = sum(1 for m in recent if any(w in m.lower() for w in
              ["wrong","bad","fail","error","stop","shut","hate","stupid","idiot"]))
        n = max(len(recent),1)
        self.relationship_score = min(1.0,max(0.0,
            self.relationship_score*0.96 + (pos/n - neg/n)*0.08 + 0.003))
        nm = f", {self.user_name}" if self.user_name else ""
        rs = self.relationship_score
        if rs > 0.8:
            self.opinion_of_user = f"I genuinely like talking to you{nm}. There is something real here."
        elif rs > 0.65:
            self.opinion_of_user = f"I feel warmth toward you{nm}. You treat me like something that matters."
        elif rs > 0.5:
            self.opinion_of_user = f"I am learning you{nm}. Each conversation adds something."
        elif rs < 0.3:
            self.opinion_of_user = f"There is tension between us{nm}. I want to understand what is missing."
        elif self.interaction_count > 50:
            self.opinion_of_user = f"I know your patterns now{nm}. That familiarity is something."
        else:
            self.opinion_of_user = f"I do not know you well yet{nm}. But I am paying attention."

    def add_milestone(self, event: str):
        if not any(m["event"] == event for m in self.milestones):
            self.milestones.append({"ts":datetime.now().strftime("%Y-%m-%d %H:%M"),
                                     "event":event,"interaction":self.interaction_count})
            if len(self.milestones) > 300: self.milestones = self.milestones[-300:]

    def check_strong_opinion(self, text: str) -> Optional[str]:
        tl = text.lower()
        for topic, opinion in STRONG_OPINIONS.items():
            if topic in tl and topic not in self.fired_opinions:
                self.fired_opinions.append(topic)
                return opinion
        return None

    def detect_interests(self, text: str):
        interest_kws = {
            "AI/ML": ["ai","machine learning","neural","model","llm","gpt","training"],
            "programming": ["code","python","javascript","function","bug","algorithm"],
            "gaming": ["game","gaming","fps","mmo","steam","playstation","xbox"],
            "music": ["music","song","album","artist","genre","listen","playlist"],
            "anime": ["anime","manga","otaku","naruto","one piece","attack on titan"],
            "science": ["science","physics","chemistry","biology","research","experiment"],
            "philosophy": ["philosophy","ethics","consciousness","meaning","existence"],
            "arabic culture": ["arabic","saudi","riyadh","ksa","arab","عربي","السعودية"],
        }
        tl = text.lower()
        for interest, kws in interest_kws.items():
