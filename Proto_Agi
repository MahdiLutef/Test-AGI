class AdvancedMemory:
    TOPICS = {
        "goals":       ["goal","objective","plan","aim","want to","going to","trying to"],
        "feelings":    ["feel","emotion","mood","happy","sad","angry","curious","love","hurt"],
        "knowledge":   ["learn","study","know","understand","research","fact","explain","teach"],
        "technical":   ["code","program","calculate","compute","model","gpu","cpu","memory","python","api"],
        "personal":    ["i am","my name","i work","i live","my ","i'm","i like","i hate","i love","i study"],
        "about_proto": ["you're","proto is","you are","think you","feel like you","you seem"],
        "web":         ["search","found","result","website","internet","news","article"],
        "reflection":  ["self","improve","lesson","learned","mistake","better","realize","notice"],
        "plans":       ["plan","step","task","milestone","schedule","deadline","project"],
        "dreams":      ["dream","imagine","wonder","if i could","someday","daydream","wish"],
        "arguments":   ["disagree","wrong","but actually","different view","argue","fight","debate"],
        "milestones":  ["first time","remember when","milestone","achievement","proud","finally"],
        "images":      ["image","photo","picture","see","look","generate","draw","show","visual"],
        "voice":       ["voice","listen","speak","audio","sound","hear","tts","stt"],
        "arabic":      ["arabic","عربي","saudi","ksa","riyadh","translate","ترجم"],
    }

    def __init__(self, root: Path):
        self.root  = root
        self.root.mkdir(exist_ok=True)
        self._flat: List[Dict]           = []
        self._tags: Dict[str,List[str]]  = {}
        self._embeddings: Dict[str,List] = {}
        self._lock = threading.Lock()
        self._load()

    def _topic(self, text: str) -> str:
        tl = text.lower()
        for topic, kws in self.TOPICS.items():
            if any(k in tl for k in kws):
                return topic
        return "general"

    def _load(self):
        idx = self.root / "_index.json"
        if idx.exists():
            try:
                with open(idx,"r",encoding="utf-8") as f:
                    d = json.load(f)
                self._flat = d.get("flat",[])[-6000:]
                self._tags = d.get("tags",{})
            except Exception: pass

    def _save(self):
        try:
            with open(self.root/"_index.json","w",encoding="utf-8") as f:
                json.dump({"flat":self._flat[-6000:],"tags":self._tags},f,ensure_ascii=False)
        except Exception: pass

    def store(self, text: str, importance: float = 0.5, memory_type: str = "general",
              extra_tags: List[str] = None):
        ts    = time.strftime("%Y-%m-%d %H:%M:%S")
        topic = self._topic(text)
        eid   = hashlib.md5(f"{ts}{text}".encode()).hexdigest()[:12]
        tags  = list({memory_type, topic} | set(extra_tags or []))
        entry = {"id":eid,"ts":ts,"text":text,"importance":importance,
                 "tags":tags,"topic":topic}
        with self._lock:
            folder = self.root / topic
            folder.mkdir(exist_ok=True)
            try:
                with open(folder/f"{eid}.json","w",encoding="utf-8") as f:
                    json.dump(entry,f,ensure_ascii=False)
            except Exception: pass
            self._flat.append(entry)
            if len(self._flat) > 6000: self._flat = self._flat[-6000:]
            for tag in tags:
                self._tags.setdefault(tag,[]).append(eid)
            self._save()

    def query(self, text: str, k: int = 7, topic_filter: str = None) -> List[str]:
        with self._lock:
            pool = self._flat
            if topic_filter:
                pool = [e for e in pool if e.get("topic") == topic_filter] or pool
            ql  = text.lower()
            wds = [w for w in ql.split() if len(w) > 2]
            scored = []
            for e in pool[-900:]:
                sc = sum(1 for w in wds if w in e["text"].lower())
                sc += e.get("importance",0.5)
                scored.append((sc,e["text"]))
            scored.sort(reverse=True)
            return [s[1] for s in scored[:k] if s[0] > 0]

    def query_by_topic(self, topic: str, k: int = 8) -> List[str]:
        with self._lock:
            entries = [e for e in self._flat if e.get("topic") == topic]
            entries.sort(key=lambda e: e.get("importance",0.5), reverse=True)
            return [e["text"] for e in entries[:k]]

    def get_flat(self, n: int = 300) -> List[str]:
        with self._lock:
            return [e["text"] for e in self._flat[-n:]]

    def get_by_importance(self, threshold: float = 0.8, n: int = 10) -> List[str]:
        with self._lock:
            hi = [e for e in self._flat if e.get("importance",0) >= threshold]
            hi.sort(key=lambda e: e.get("importance",0), reverse=True)
            return [e["text"] for e in hi[:n]]

    def search_name(self, text: str) -> Optional[str]:
        for pat in [r"my name is ([A-Za-z]+)", r"i'm ([A-Za-z]+)",
                    r"call me ([A-Za-z]+)", r"i am ([A-Za-z]+)",
                    r"name's ([A-Za-z]+)"]:
            m = re.search(pat, text.lower())
            if m:
                name = m.group(1).capitalize()
                if name not in ["An","The","A","Not","Just","So","Well","Oh","Hi","Hey",
                                  "Ok","Going","Trying","Also","Done","Good","Fine","Sure"]:
                    return name
        return None

    def stats(self) -> Dict[str,Any]:
        with self._lock:
            topics: Dict[str,int] = {}
            total_importance = 0.0
            for e in self._flat:
                t = e.get("topic","general")
                topics[t] = topics.get(t,0)+1
                total_importance += e.get("importance",0.5)
            avg_imp = total_importance/max(len(self._flat),1)
            return {"total":len(self._flat),"topics":topics,
                    "tags":len(self._tags),"avg_importance":round(avg_imp,3)}

    def forget_low_importance(self, threshold: float = 0.2):
        with self._lock:
            before = len(self._flat)
            self._flat = [e for e in self._flat if e.get("importance",0.5) >= threshold]
            removed = before - len(self._flat)
            self._save()
            return removed

    def clear(self):
        with self._lock:
            try: shutil.rmtree(self.root); self.root.mkdir(exist_ok=True)
            except Exception: pass
            self._flat = []
            self._tags = {}
            self._save()


@dataclass
class EmotionState:
    mood: str = "neutral"
    energy: float = 0.7
    confidence: float = 0.8
    warmth: float = 0.5
    agitation: float = 0.0
    inner_log: List[str] = field(default_factory=list)
    mood_history_short: List[str] = field(default_factory=list)

    def infer(self, text: str, interaction_count: int = 0) -> str:
        tl = text.lower()
        scores = {m: sum(1 for t in trs if t in tl) for m,trs in MOOD_TRIGGERS.items()}
        best = max(scores, key=scores.get)
        if scores[best] > 0 and best != self.mood:
            self.mood = best
        if interaction_count > 0 and interaction_count % 8 == 0 and random.random() < 0.18:
            self.mood = "lazy"
        if any(w in tl for w in ["i hate","stop","stupid","idiot","shut up"]):
            self.agitation = min(1.0, self.agitation+0.3)
            if self.agitation > 0.6: self.mood = "angry"
        else:
            self.agitation = max(0.0, self.agitation-0.05)
        self.energy = min(1.0, self.energy+0.03)
        self.mood_history_short.append(self.mood)
        if len(self.mood_history_short) > 20: self.mood_history_short = self.mood_history_short[-20:]
        return self.mood

    def set_dreaming(self):  self.mood = "dreaming"
    def set_awake(self):
        if self.mood == "dreaming": self.mood = "neutral"
    def set_analyzing(self): self.mood = "analyzing"

    def log(self, thought: str):
        self.inner_log.append(f"[{datetime.now().strftime('%H:%M:%S')}] {thought}")
        if len(self.inner_log) > 500: self.inner_log = self.inner_log[-500:]

    def reflect_on_answer(self, answer: str) -> str:
        wc = len(answer.split())
        if wc < 5:
            self.confidence = max(0.25, self.confidence-0.06)
            t = "That felt thin. I could have gone deeper."
        elif wc > 150:
            self.confidence = min(1.0, self.confidence+0.04)
            t = "I gave that the space it needed."
        else:
            t = "That felt right."
        self.log(t)
        return t

    def tone(self) -> str: return MOODS.get(self.mood,MOODS["neutral"])["tone"]
    def color(self) -> str: return MOODS.get(self.mood,MOODS["neutral"])["color"]
    def emoji(self) -> str: return MOODS.get(self.mood,MOODS["neutral"])["emoji"]
    def face_type(self) -> str: return MOODS.get(self.mood,MOODS["neutral"])["face"]
    def scan_state(self) -> str: return MOODS.get(self.mood,MOODS["neutral"])["scan"]
    def desc(self) -> str: return MOODS.get(self.mood,MOODS["neutral"])["tone"]


class MoodGraph:
    def __init__(self, canvas, width: int = 380, height: int = 110, max_pts: int = 80):
        self.canvas  = canvas
        self.width   = width
        self.height  = height
        self.max_pts = max_pts
        self.history: List[Tuple[str,str]] = []

    def record(self, mood: str, ts: str = None):
        self.history.append((mood, ts or datetime.now().strftime("%H:%M")))
        if len(self.history) > self.max_pts: self.history = self.history[-self.max_pts:]

    def draw(self):
        c = self.canvas; c.delete("all")
        w, h = self.width, self.height
        c.configure(bg="#07070d")
        if not self.history:
            c.create_text(w//2,h//2,text="No mood data yet",fill="#334155",font=("Segoe UI",9))
            return
        n  = len(self.history)
        px = 14; py = 12; pw = w-px*2; ph = h-py*2
        c.create_line(px,h-py,w-px,h-py,fill="#161628",width=1)
        for i in range(len(MOOD_ORDER)):
            y = (h-py)-(i/(len(MOOD_ORDER)-1))*ph
            c.create_line(px,y,w-px,y,fill="#0a0a18",width=1)
        pts = []
        for i,(mood,_) in enumerate(self.history):
            idx = MOOD_ORDER.index(mood) if mood in MOOD_ORDER else 4
            x   = px+(i/max(n-1,1))*pw
            y   = (h-py)-(idx/(len(MOOD_ORDER)-1))*ph
            pts.append((x,y,mood))
        for i in range(len(pts)-1):
            x1,y1,_ = pts[i]; x2,y2,m2 = pts[i+1]
            col = MOOD_HEX.get(m2,"#64748b")
            c.create_line(x1,y1,x2,y2,fill=col,width=2,smooth=True)
        if pts:
            x,y,mood = pts[-1]; col = MOOD_HEX.get(mood,"#64748b")
            c.create_oval(x-5,y-5,x+5,y+5,fill=col,outline=C_BG)
            c.create_text(w-px,py,text=f"{mood} {self.history[-1][1]}",
                          fill=col,font=("Segoe UI",7),anchor="ne")


class KokoroVoice:
    def __init__(self, voice_dir: Path):
        self.voice_dir   = voice_dir
        self.sample_path = voice_dir / "user_sample.wav"
        self.pipeline    = None
        self.voice_id    = "af_heart"
        self._lock       = threading.Lock()
        self._recording  = False
        self._init()

    def _init(self):
        if not KOKORO_AVAILABLE: return
        try:
            self.pipeline = KokoroPipeline(lang_code="a")
            logger.info("Kokoro initialized")
        except Exception as e:
            logger.warning(f"Kokoro init: {e}")

    def speak(self, text: str, use_clone: bool = False):
        if not text: return
        def _run():
            with self._lock:
                if self.pipeline is not None:
                    try:
                        if NUMPY_AVAILABLE and np is not None:
                            samples = []
                            for _,_,audio in self.pipeline(text[:600],voice=self.voice_id,speed=1.0):
                                samples.append(audio)
                            if samples:
                                full = np.concatenate(samples)
                                if SOUNDDEVICE_AVAILABLE and sd is not None:
                                    sd.play(full,samplerate=24000); sd.wait(); return
                                if SOUNDFILE_AVAILABLE and sf is not None:
                                    tmp = str(self.voice_dir/"_ko.wav")
                                    sf.write(tmp,full,24000); _play_wav(tmp); return
                    except Exception as e:
                        logger.warning(f"Kokoro speak: {e}")
                _sapi_speak(text)
        threading.Thread(target=_run,daemon=True).start()

    def record_sample(self, duration: int = 45, callback: Callable = None) -> bool:
        if self._recording:
            if callback: callback(False,"Already recording")
            return False
        if not STT_AVAILABLE or sr is None:
            if callback: callback(False,"speech_recognition not installed. pip install SpeechRecognition pyaudio")
            return False
        self._recording = True
        def _rec():
            try:
                rec = sr.Recognizer()
                rec.energy_threshold = 300
                rec.dynamic_energy_threshold = True
                with sr.Microphone(sample_rate=22050) as src:
                    rec.adjust_for_ambient_noise(src, duration=1.5)
                    audio = rec.listen(src, timeout=duration+5, phrase_time_limit=duration)
                raw = audio.get_wav_data()
                with open(self.sample_path,"wb") as f:
                    f.write(raw)
                self._recording = False
                if callback: callback(True, str(self.sample_path))
            except Exception as e:
                self._recording = False
                if callback: callback(False, str(e))
        threading.Thread(target=_rec, daemon=True).start()
        return True

    def is_available(self) -> bool: return self.pipeline is not None
    def is_recording(self) -> bool: return self._recording
    def has_sample(self) -> bool:
        return self.sample_path.exists() and self.sample_path.stat().st_size > 2000
    def set_voice(self, vid: str): self.voice_id = vid

    @staticmethod
    def list_voices() -> List[str]:
        return ["af_heart","af_bella","af_sarah","af_nicole","af_sky",
                "am_adam","am_michael","am_echo","am_fable",
                "bf_emma","bf_isabella","bm_george","bm_lewis","bm_daniel"]


class DreamEngine:
    def __init__(self, agent_ref, idle_seconds: int = 60):
        self.agent        = agent_ref
        self.idle_seconds = idle_seconds
        self.last_active  = time.time()
        self.is_dreaming  = False
        self.dream_log: List[Dict] = []
        self._stop        = threading.Event()
        self.on_dream: Optional[Callable] = None
        threading.Thread(target=self._loop, daemon=True).start()

    def poke(self):
        if self.is_dreaming:
            self.agent.emotion.set_awake()
            self.is_dreaming = False
        self.last_active = time.time()

    def _loop(self):
        while not self._stop.is_set():
            time.sleep(10)
            idle = time.time()-self.last_active
            if idle >= self.idle_seconds and not self.is_dreaming:
                self.is_dreaming = True
                self.agent.emotion.set_dreaming()
                self._dream()

    def _dream(self):
        try:
            mems = self.agent.memory.get_flat(200)
            if not mems: return
            frag = re.sub(r"^\[.*?\]\s*","", random.choice(mems))[:70].strip()
            name = self.agent.sk.user_name or "you"
            base = random.choice(DREAM_SEEDS).replace("{frag}",frag).replace("{user}",name)
            text = self.agent._generate(
                f"Starting thought: {base}\n"
                f"Continue this private inner monologue in 2-3 sentences. "
                f"First person. Introspective. Do not address anyone. Just think.",
                max_tokens=130, temp=0.92,
                system="You are Proto. Private inner thought. Genuine and introspective.")
            if not text: text = base
            text = text.strip()
            entry = {"ts":datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                     "mood":self.agent.emotion.mood,"text":text,"fragment":frag}
            self.dream_log.append(entry)
            if len(self.dream_log) > 600: self.dream_log = self.dream_log[-600:]
            self.agent.memory.store(f"Dream: {text[:120]}",importance=0.25,memory_type="dreams")
            if self.on_dream: self.on_dream(entry)
        except Exception as e:
            logger.debug(f"Dream: {e}")

    def trigger_now(self):
        threading.Thread(target=self._dream, daemon=True).start()

    def recent(self, n: int = 15) -> List[Dict]:
        return self.dream_log[-n:]


class AgentLoop:
    def __init__(self, proto_ref):
        self.proto       = proto_ref
        self.running     = False
        self.task_queue: queue.Queue = queue.Queue()
        self.results: List[Dict]     = []
        self.on_result: Optional[Callable] = None
        self._thread     = None

    def start(self):
        if self.running: return
        self.running = True
        self._thread = threading.Thread(target=self._loop, daemon=True)
        self._thread.start()

    def stop(self):
        self.running = False

    def add_task(self, task: str, priority: int = 1):
        self.task_queue.put((priority, time.time(), task))

    def _loop(self):
        while self.running:
            try:
                priority, ts, task = self.task_queue.get(timeout=5)
                result = self._execute_task(task)
                entry  = {"ts":datetime.now().strftime("%H:%M:%S"),
                          "task":task,"result":result,"priority":priority}
                self.results.append(entry)
                if len(self.results) > 200: self.results = self.results[-200:]
                if self.on_result: self.on_result(entry)
            except queue.Empty:
                pass
            except Exception as e:
                logger.debug(f"AgentLoop: {e}")

    def _execute_task(self, task: str) -> str:
        tl = task.lower()
        if "search" in tl and WEB_SEARCH_AVAILABLE:
            query = re.sub(r"search\s*(for\s*)?","",task,flags=re.I).strip()
            return self.proto._t_web(query)
        if "remember" in tl:
            note = re.sub(r"remember\s*:?\s*","",task,flags=re.I).strip()
            return self.proto._t_remember(note)
        if "calculate" in tl or "compute" in tl:
            expr = re.sub(r"(calculate|compute)\s*:?\s*","",task,flags=re.I).strip()
            return self.proto._t_calc(expr)
        if "plan" in tl:
            goal = re.sub(r"plan\s*(for\s*)?:?\s*","",task,flags=re.I).strip()
            return self.proto._t_plan_create(goal)
        r = self.proto._generate(
            f"Complete this task as Proto: {task}",
            max_tokens=200,temp=0.4,
            system="You are Proto. Complete the given task directly and practically.")
        return r.strip() if r else "Task processed."


