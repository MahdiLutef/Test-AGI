            elapsed = time.time()-t0
            q.put(("answer",  answer))
            q.put(("mono",    mono))
            q.put(("status",  f"DONE  ·  {len(answer.split())} words  ·  {elapsed:.1f}s"))
            if th: q.put(("th_full",th))
            q.put(("updates", None))
            if tts_en_var.get():
                if proto.kokoro.is_available(): proto.kokoro.speak(answer,use_clone=use_clone_var.get())
