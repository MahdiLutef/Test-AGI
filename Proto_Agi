    def _draw_face():
        c = face_canvas; c.delete("all")
        W,H = 420,200; cx,cy = W//2, H//2-10
        color  = proto.emotion.color()
        phase  = face_phase[0]
        ftype  = proto.emotion.face_type()
        np2    = noise_phase[0]

        for i in range(0,H,4):
            alpha_factor = 0.03 + 0.02*math.sin(i*0.1+phase)
            if i % 8 == 0:
                scan_alpha = 0.15 if abs(i - (scan_line_y[0] % H)) < 6 else alpha_factor
                c.create_line(0,i,W,i,fill="#001a00",width=1)

        for xi in range(0,W,20):
            c.create_line(xi,0,xi,H,fill="#050510",width=1)

        for r_i,alpha in [(80,0.4),(65,0.6),(50,0.8),(35,1.0)]:
            pulse = r_i + math.sin(phase*1.6)*4 + math.sin(phase*3.1+r_i)*1.5
            noise = math.sin(np2*7.3+r_i)*2
            c.create_oval(cx-pulse+noise,cy-pulse,cx+pulse+noise,cy+pulse,
                          fill="",outline=color,width=max(1,int(alpha*2)))

        eye_y = cy-10
        eye_spread = 13
        bv = face_blink[0]
        for ex in [cx-eye_spread,cx+eye_spread]:
            eh_outer = max(2,int(10*bv))
            eh_inner = max(1,int(6*bv))
            c.create_oval(ex-8,eye_y-eh_outer,ex+8,eye_y+eh_outer,fill="#0a0a14",outline=color,width=1)
            if bv > 0.3:
                c.create_oval(ex-4,eye_y-eh_inner,ex+4,eye_y+eh_inner,fill=color,outline="")
                pupil_offset_x = math.sin(phase*0.4)*2
                pupil_offset_y = math.cos(phase*0.3)*1.5
                c.create_oval(ex-2+pupil_offset_x,eye_y-2+pupil_offset_y,
                              ex+2+pupil_offset_x,eye_y+2+pupil_offset_y,
                              fill="#000000",outline="")
                c.create_oval(ex-1+pupil_offset_x,eye_y-2+pupil_offset_y,
                              ex+1+pupil_offset_x,eye_y-1+pupil_offset_y,
                              fill="white",outline="")

        nose_y = cy+4
        c.create_line(cx,nose_y-4,cx-3,nose_y+4,fill=color,width=1)
        c.create_line(cx,nose_y-4,cx+3,nose_y+4,fill=color,width=1)

        mouth_y = cy+18
        if ftype == "happy" or ftype == "affectionate" or ftype == "proud" or ftype == "excited":
            sm = math.sin(phase)*2
            c.create_arc(cx-16,mouth_y-6+sm,cx+16,mouth_y+8+sm,start=200,extent=140,style="arc",outline=color,width=2)
            c.create_line(cx-16,mouth_y-1+sm,cx-16+3,mouth_y+1+sm,fill=color,width=1)
            c.create_line(cx+16,mouth_y-1+sm,cx+16-3,mouth_y+1+sm,fill=color,width=1)
        elif ftype in ("frustrated","disagreeing","melancholy"):
            c.create_arc(cx-16,mouth_y,cx+16,mouth_y+12,start=20,extent=140,style="arc",outline=color,width=2)
        elif ftype == "angry":
            c.create_line(cx-16,mouth_y-16,cx-8,mouth_y-10,fill=color,width=2)
            c.create_line(cx+16,mouth_y-16,cx+8,mouth_y-10,fill=color,width=2)
            c.create_line(cx-14,mouth_y+4,cx+14,mouth_y,fill=color,width=2)
        elif ftype == "curious" or ftype == "analyzing":
            c.create_arc(cx-10,mouth_y,cx+10,mouth_y+8,start=0,extent=180,style="arc",outline=color,width=2)
            c.create_oval(cx+14,eye_y-14,cx+20,eye_y-8,fill="",outline=color,width=1)
        elif ftype == "uncertain":
            c.create_arc(cx-12,mouth_y,cx+12,mouth_y+10,start=15,extent=150,style="arc",outline=color,width=2)
        elif ftype == "lazy":
            c.create_line(cx-10,mouth_y+2,cx+10,mouth_y+2,fill=color,width=1)
            c.create_line(cx-5,mouth_y-2,cx+5,mouth_y,fill=color,width=1)
        elif ftype == "dreaming":
            c.create_arc(cx-12,mouth_y-2,cx+12,mouth_y+8,start=210,extent=120,style="arc",outline=color,width=1)
            for di,ds in [(6,6),(12,4),(18,3)]:
                bubble_x = cx+22+di
                c.create_oval(bubble_x-ds,eye_y-20-di,bubble_x+ds,eye_y-20-di+ds*2,
                              fill="",outline=color,width=1)
        else:
            c.create_line(cx-12,mouth_y+3,cx+12,mouth_y+1,fill=color,width=2)

        glitch_chance = 0.15 if proto.emotion.agitation > 0.5 else 0.04
        if random.random() < glitch_chance:
            gy = random.randint(cy-40,cy+40)
            gw = random.randint(20,80)
            gx = random.randint(cx-60,cx+60-gw)
            c.create_rectangle(gx,gy,gx+gw,gy+random.randint(2,6),
                                fill=color,outline="",stipple="gray50")

        circuit_points = [(cx-30,cy-35),(cx+35,cy-28),(cx-25,cy+30),(cx+28,cy+32)]
        for cpx,cpy in circuit_points:
            c.create_oval(cpx-2,cpy-2,cpx+2,cpy+2,fill=color,outline="")
            c.create_line(cpx,cpy,cx,cy,fill=color,width=1,dash=(2,6))

        c.create_text(cx+52,cy,text=proto.emotion.emoji(),
                      fill=color,font=("Segoe UI Emoji",20),anchor="w")

        name_disp = f"PROTO  ·  {proto.sk.user_name.upper()}" if proto.sk.user_name else "PROTO"
        c.create_text(cx,H-22,text=name_disp,fill=color,font=FSCAN,anchor="center")

        rel = proto.sk.relationship_score
