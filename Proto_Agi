        c.create_rectangle(cx-50,H-12,cx+50,H-8,fill="#0a0a14",outline=color,width=1)
        c.create_rectangle(cx-50,H-12,cx-50+bar_w,H-8,fill=color,outline="")
        c.create_text(cx+56,H-10,text=f"{rel:.2f}",fill=color,font=FSCAN,anchor="w")

        sl_y = scan_line_y[0] % H
        c.create_line(0,sl_y,W,sl_y,fill=C_SCAN,width=1,stipple="gray25")
        c.create_line(0,sl_y+1,W,sl_y+1,fill=C_SCAN,width=1,stipple="gray75")

