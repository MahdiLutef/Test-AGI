            if not STT_AVAILABLE: q.put(("sys","speech_recognition not installed.")); return
            call_active[0] = True
            call_btn.configure(fg=C_RED,text="⏹")
            q.put(("sys","CALL_ACTIVE — speak now — click ⏹ to end"))
            threading.Thread(target=_call_loop,daemon=True).start()

    def _call_loop():
        rec = sr.Recognizer() if sr is not None else None
        if rec is None: return
        while call_active[0]:
            try:
                with sr.Microphone() as src:
                    rec.adjust_for_ambient_noise(src,duration=0.3)
                    audio = rec.listen(src,timeout=5,phrase_time_limit=18)
                text = rec.recognize_google(audio)
                if text and call_active[0]:
                    q.put(("call_in",text))
                    answer,th,mono = proto.step(text)
                    last_resp[0] = answer
                    q.put(("answer",answer)); q.put(("mono",mono)); q.put(("updates",None))
                    if th: q.put(("th_full",th))
                    if proto.kokoro.is_available(): proto.kokoro.speak(answer,use_clone=use_clone_var.get())
                    else: _sapi_speak(answer)
            except Exception:
                if call_active[0]: time.sleep(0.5)

    def _mic_once():
        if thinking[0] or call_active[0]: return
        q.put(("sys","LISTENING…"))
        def _s():
            if sr is None: return
            rec = sr.Recognizer()
            try:
                with sr.Microphone() as src:
                    rec.adjust_for_ambient_noise(src,duration=0.3)
                    audio = rec.listen(src,timeout=5,phrase_time_limit=18)
                txt = rec.recognize_google(audio)
                if txt: root.after(0,lambda: (user_var.set(txt),_on_send()))
            except Exception as e: q.put(("sys",f"STT: {e}"))
        threading.Thread(target=_s,daemon=True).start()

