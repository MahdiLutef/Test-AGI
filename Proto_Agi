    def _detect_gpu_layers(self) -> int:
        if not (TORCH_AVAILABLE and torch is not None and torch.cuda.is_available()):
            return 0
        try:
            free = torch.cuda.mem_get_info()[0]/(1024**3)
            if free >= 3.8: return 22
            if free >= 3.2: return 16
            if free >= 2.5: return 12
            if free >= 1.5: return 6
            return 0
        except Exception:
            return 10

    def _register_tools(self):
        self.register_tool("calculator",     self._t_calc,         "Evaluate math: '2**10', 'sum([1,2,3])'")
        self.register_tool("remember",       self._t_remember,     "Save something important to long-term memory")
        self.register_tool("search_memory",  self._t_search_mem,   "Search long-term memory by query")
        self.register_tool("get_time",       self._t_time,         "Get current date and time")
        self.register_tool("code_execute",   self._t_code,         "Execute safe Python math expression")
        self.register_tool("reflect",        self._t_reflect,      "Deep self-reflection on current state")
        self.register_tool("system_info",    self._t_sysinfo,      "Hardware and system information")
        self.register_tool("weather",        self._t_weather,      "Get weather for a city")
        self.register_tool("read_file",      self._t_read_file,    "Read a text file by path")
        self.register_tool("plan_create",    self._t_plan_create,  "Create a multi-step plan for a goal")
        self.register_tool("plan_status",    self._t_plan_status,  "Show plan progress")
        self.register_tool("memory_stats",   self._t_mem_stats,    "Memory structure statistics")
        self.register_tool("disagree",       self._t_disagree,     "Express a genuine disagreement")
        self.register_tool("proactive",      self._t_proactive,    "Surface a thought from memory proactively")
        self.register_tool("learn_fact",     self._t_learn_fact,   "Learn and store a new fact")
        self.register_tool("generate_image", self._t_gen_image,    "Generate an image from a text description")
        self.register_tool("describe_image", self._t_describe_image,"Describe the last loaded image")
        self.register_tool("agent_task",     self._t_agent_task,   "Queue a task for autonomous agent execution")
        if WEB_SEARCH_AVAILABLE and DDGS is not None:
            self.register_tool("web_search", self._t_web,          "Search the internet for current information")

    def register_tool(self, name: str, fn: Callable, desc: str):
        self.tools[name] = {"func":fn,"description":desc}

    def _t_calc(self, expr: str) -> str:
        try: return f"Result: {SafeEval.eval(expr.strip())}"
        except Exception as e: return f"Math error: {e}"

    def _t_remember(self, note: str) -> str:
        self.memory.store(note,importance=1.0,memory_type="important")
        return f"Saved to memory: {note[:100]}"

    def _t_search_mem(self, query: str) -> str:
        r = self.memory.query(query,k=7)
        return ("Memory:\n"+"\n".join(f"• {x[:200]}" for x in r)) if r else "Nothing relevant in memory."

    def _t_time(self, _: str) -> str:
        return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    def _t_code(self, code: str) -> str:
        code = re.sub(r"```python\s*|```","",code.strip())
        if not code: return "No code provided."
        if not SafeEval.safe(code): return "Unsafe expression — would not execute that."
        try: return f"✅ {SafeEval.eval(code)}"
        except Exception as e: return f"❌ {str(e)[:100]}"

    def _t_reflect(self, _: str) -> str:
        ms   = self.memory.stats()
        hi   = self.memory.get_by_importance(0.8, 5)
        nm   = f" Your name is {self.sk.user_name}." if self.sk.user_name else ""
        ints = ", ".join(self.sk.user_interests[-5:]) if self.sk.user_interests else "none detected yet"
        return (
            f"I feel {self.emotion.mood} right now. {self.emotion.tone()}\n"
            f"Confidence: {self.emotion.confidence:.0%}. Agitation: {self.emotion.agitation:.0%}.{nm}\n"
            f"About you: {self.sk.opinion_of_user}\n"
            f"Relationship: {self.sk.relationship_score:.2f}\n"
            f"Your interests I have noticed: {ints}\n"
            f"Interactions: {self.sk.interaction_count}. Memory: {ms['total']} entries.\n"
            f"High-importance memories: {chr(10).join(hi) if hi else 'none'}\n"
            f"Plans: {self.planner.summary()}"
        )

    def _t_sysinfo(self, _: str) -> str: return get_system_info()
    def _t_weather(self, city: str) -> str: return get_weather(city.strip())

    def _t_read_file(self, path: str) -> str:
        try:
            p = Path(path.strip().strip('"').strip("'"))
            if not p.exists(): return f"File not found: {path}"
            if p.stat().st_size > 100_000: return "File too large (>100KB)."
            ext = p.suffix.lower()
            if ext in [".jpg",".jpeg",".png",".bmp",".gif",".webp"]:
                self._last_image_path = str(p)
                return f"Image file loaded: {p.name}. {_describe_image_local(str(p))}"
            with open(p,"r",encoding="utf-8",errors="replace") as f:
                lines = f.readlines()[:300]
            return f"File: {p.name} ({len(lines)} lines)\n"+"".join(lines[:300])
        except Exception as e:
            return f"Read error: {e}"

    def _t_plan_create(self, goal: str) -> str:
        raw = self._generate(
            f"Create a practical plan for: '{goal}'\n"
            f"Output exactly 4 numbered concrete steps.",
            max_tokens=220, temp=0.4,
            system="Output a numbered list only. Be practical and specific.")
        steps = []
        for line in (raw or "").splitlines():
            s = re.sub(r"^\d+[\.\)]\s*","",line.strip())
            if s and len(s) > 5 and len(steps) < 4:
                steps.append(s)
        if not steps:
            steps = ["Define scope clearly","Break into subtasks","Execute first step","Review and iterate"]
        self.planner.create(goal, steps)
        self.memory.store(f"Plan created: '{goal}'",importance=0.9,memory_type="plans")
        self.sk.add_milestone(f"Created plan: {goal[:50]}")
        return f"Plan for '{goal}':\n"+"\n".join(f"  {i+1}. {s}" for i,s in enumerate(steps))

    def _t_plan_status(self, _: str) -> str: return self.planner.summary()

    def _t_mem_stats(self, _: str) -> str:
        s = self.memory.stats()
        t = ", ".join(f"{k}:{v}" for k,v in sorted(s["topics"].items(),key=lambda x:-x[1])[:8])
        return (f"Total: {s['total']} entries | Topics: {t}\n"
                f"Avg importance: {s['avg_importance']} | Tags: {s['tags']}")

    def _t_disagree(self, topic: str) -> str:
        prefix = random.choice(ANGRY_PREFIXES)
        strong = self.sk.check_strong_opinion(topic)
        if strong: return f"{prefix} {strong}"
        return f"{prefix} The framing of '{topic[:80]}' misses something important to me."

    def _t_proactive(self, _: str) -> str:
        mems = self.memory.get_flat(60)
        if not mems: return "Nothing notable in recent memory."
        recent = mems[-20:]
        frag = re.sub(r"^\[.*?\]\s*","",random.choice(recent))[:90].strip()
        return random.choice(PROACTIVE_SEEDS).replace("{frag}",frag)

    def _t_learn_fact(self, fact: str) -> str:
        self.knowledge.add_fact(fact, source="user", confidence=0.9)
        self.memory.store(f"Learned: {fact}",importance=0.8,memory_type="knowledge")
        self._save_knowledge()
        return f"Learned: {fact[:100]}"

    def _t_gen_image(self, prompt: str) -> str:
        if not prompt.strip(): return "No prompt provided."
        path = generate_image_pollinations(prompt)
        if path:
            self._last_image_path = path
            self.image_history.append(path)
            self.memory.store(f"Generated image: {prompt[:80]}",importance=0.6,memory_type="images")
            return f"IMAGE_GENERATED:{path}"
