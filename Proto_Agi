            "self_discoveries":len(self.knowledge.self_discoveries),
            "image_gen":       "Pollinations.ai",
            "images_generated":len(self.image_history),
            "last_seen":       self.sk.last_seen,
        }


def _sp(name: str) -> Path:
    safe = "".join(c for c in name if c.isalnum() or c in "._- ").strip() or "session"
    return SESSIONS_DIR/(safe+".json")

def list_sessions() -> List[str]:
    try: return sorted(p.stem for p in SESSIONS_DIR.glob("*.json"))
    except Exception: return []

def save_session(proto: Proto, name: str) -> Tuple[bool,Optional[str]]:
    try:
        with open(_sp(name),"w",encoding="utf-8") as f:
            json.dump({"name":name,"ts":time.strftime("%Y-%m-%d %H:%M:%S"),
                       "interactions":proto.sk.interaction_count,
                       "emotion":{"mood":proto.emotion.mood,
                                  "confidence":proto.emotion.confidence,
                                  "warmth":proto.emotion.warmth}},
                      f,indent=2,ensure_ascii=False)
        return True, None
    except Exception as e: return False, str(e)

def load_session(proto: Proto, name: str) -> Tuple[bool,Optional[str]]:
    p = _sp(name)
    if not p.exists(): return False,"not found"
    try:
        with open(p,"r",encoding="utf-8") as f: d = json.load(f)
        em = d.get("emotion",{})
        proto.emotion.mood       = em.get("mood","neutral")
        proto.emotion.confidence = em.get("confidence",0.8)
        proto.emotion.warmth     = em.get("warmth",0.5)
        proto.sk.interaction_count = d.get("interactions",0)
        return True, None
    except Exception as e: return False, str(e)

def delete_session(name: str) -> Tuple[bool,Optional[str]]:
    p = _sp(name)
    try:
        if p.exists(): p.unlink(); return True,None
        return False,"not found"
    except Exception as e: return False, str(e)


def _he(t: str) -> str:
    return t.replace("&","&amp;").replace("<","&lt;").replace(">","&gt;").replace('"',"&quot;")

